#!/usr/bin/env python3

"""
DevOps Monitoring Tool
Author: Roshan Kumar
"""

import os
import sys
import json
import subprocess
import requests
from datetime import datetime

# Colors
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
NC = '\033[0m'  # No color

# --- Helper ---
def run_cmd(cmd):
	result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
	return result.stdout.strip() if result.returncode == 0 else None 

# ---- System checks ----
def get_cpu():
    CPU = run_cmd("top -bn1 | grep 'Cpu(s)' | awk '{print $2}'")
    return {"cpu_usage": f"{CPU}%"}

def get_memory():
    memory = run_cmd("free | grep Mem | awk '{printf \"%.0f\", $3/$2 * 100}'")
    return {"memory_usage" : f"{memory}%"}
def get_disk():
    disk = run_cmd("df -h / | awk 'NR==2 {print $5}'")
    return {"disk_usage": f"{disk}"}

def get_services():
    services = ["ssh","cron"]
    result = {}
    for service in services:
        output = run_cmd(f"service {service} status")
        if output:
            result[service] = "running"
        else:
            result[service] = "stopped"
    return result
# ---- GitHub ----
def get_github(username):
    try:
        r = requests.get(f"https://api.github.com/users/{username}", timeout=5)
        r.raise_for_status()
       	data = r.json()
        return {
       	    "username": data['login'],
            "repos": data['public_repos'],
            "followers": data['followers']
            }
    except Exception as e:
        return {"error": str(e)}

# ---- Report ----
def generate_report():
    cpu = get_cpu()
    memory = get_memory()
    disk = get_disk()
    services = get_services()
    github = get_github("RoshanKrO7")
    report = {
    		"timestamp": str(datetime.now()),
    		"cpu": cpu,
    		"memory": memory,
    		"disk": disk,
    		"services": services,
    		"github": github
		}
    print("==========================================")
    print(f"   System Report - {str(datetime.now())[:19]}")
    print("==========================================")
    print(f"CPU:       {GREEN}{cpu['cpu_usage']}")
    print(f"Memory:    # Colors
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
NC = '\033[0m'  # No color{memory['memory_usage']}")
    print(f"Disk:      {disk['disk_usage']}")
    print(f"SSH:       {services['ssh']}")
    print(f"Cron:      {services['cron']}")
    print(f"GitHub:    {github['username']} | Repos: {github['repos']} | Followers: {github['followers']}")
    print("==========================================")
    with open("reports/report.json", "w") as f:
      	json.dump(report, f, indent=2)
    print("Report saved to reports/report.json")
    return report

# ---- CLI ----
def main():
    option = sys.argv[1] if len(sys.argv) > 1 else "--help"
    if option == "--report":
        report = generate_report()
    elif option == "--health":
        cpu = get_cpu()
        memory = get_memory()
        disk = get_disk()
        print(f"CPU:    {cpu['cpu_usage']}")
        print(f"Memory: {memory['memory_usage']}")
        print(f"Disk:   {disk['disk_usage']}")
    elif option == "--github":
        github = get_github("RoshanKrO7")
        print(f"GitHub: {github}")
    elif option == "--help":
        print("Usage: python3 monitor.py [--report|--health|--github|--help]")
    else:
        print("Unknown Option")
if __name__ == "__main__":
    main()

